# Flat File Scrubber — Environment Configuration Template
# Copy this file to .env and customize values as needed
# This file should NOT be committed to version control

# ──────────────────────────────────────────────
# STREAMLIT UI CONFIGURATION
# ──────────────────────────────────────────────
STREAMLIT_PAGE_TITLE=Flat File Scrubber
STREAMLIT_PAGE_ICON=🧹
STREAMLIT_LAYOUT=wide
STREAMLIT_SIDEBAR_STATE=expanded

# ──────────────────────────────────────────────
# SALESFORCE CONFIGURATION
# ──────────────────────────────────────────────
# Comma-separated list of supported Salesforce objects
SALESFORCE_OBJECTS=Account,Contact,Lead,Opportunity,Account to Account Relationship,Account to Contact Relationship,User,Snowflake Table - DEFAULT

# Special characters to detect and sanitize (regex pattern)
SPECIAL_CHARS_PATTERN=[\*\n\^\$\#\@\!\%\&\(\)\[\]\{\}\<\>\?\/\\|`~"\';:]

# ──────────────────────────────────────────────
# APPLICATION BEHAVIOR
# ──────────────────────────────────────────────
# Maximum number of undo history steps
UNDO_HISTORY_LIMIT=20

# API request timeout in seconds
API_REQUEST_TIMEOUT=30

# ──────────────────────────────────────────────
# IMAP CONFIGURATION (Email Intake)
# ──────────────────────────────────────────────
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_FOLDER=INBOX

# ──────────────────────────────────────────────
# API CONFIGURATION (Data Export)
# ──────────────────────────────────────────────
API_ENDPOINT_URL=
API_METHOD=POST
API_BATCH_SIZE=200
API_AUTH_HEADER=Bearer YOUR_SALESFORCE_TOKEN
API_CONTENT_TYPE=application/json

# ──────────────────────────────────────────────
# SMTP CONFIGURATION (Email Export)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# ──────────────────────────────────────────────
# AI ASSISTANT (Chat tab)
# ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
